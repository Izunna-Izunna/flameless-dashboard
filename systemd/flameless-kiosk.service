[Unit]
Description=FLAMELESS Generator Monitor – Chromium Kiosk
After=graphical.target flameless-backend.service
Wants=flameless-backend.service

[Service]
Type=simple
User=flameless
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/flameless/.Xauthority
ExecStartPre=/bin/sleep 4
ExecStart=/home/flameless/flameless-dashboard/scripts/start_kiosk.sh
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=graphical.target
